              "});\r",
              "\r",
              "// Тест 2: в ответе присутствует добавленный товар (id=1) и общее количество товаров увеличилось\r",
              "pm.test(\"Products array contains new product and totalQuantity increased\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('products');\r",
              "    pm.expect(jsonData.products).to.be.an('array');\r",
              "    \r",
              "    // Проверяем, что среди продуктов есть товар с id=1\r",
              "    const found = jsonData.products.some(p => p.id === 1);\r",
              "    pm.expect(found).to.be.true;\r",
              "    \r",
              "});"
